<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes">
  <title>Приглашение на свадьбу | 26.06.2026</title>
  
  <!-- Подключаем элегантные шрифты -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=Jost:wght@300;400&display=swap" rel="stylesheet">
  
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Jost', sans-serif;
      font-weight: 300;
      color: #f0ede8;
      background-color: #1a1d18; /* Глубокий лесной цвет, пока фон не загрузился */
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      line-height: 1.7;
      overflow-x: hidden;
    }

    /* Контейнер с фоновым изображением */
    .invitation {
      position: relative;
      width: 100%;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 3rem 1.5rem;
      background-image: url('ВАША_ФОТОГРАФИЯ_В_ЛЕСУ.jpg'); /* ЗАМЕНИТЕ ЭТУ СТРОКУ */
      background-size: cover;
      background-position: center 40%; /* Центрируем лица */
      background-repeat: no-repeat;
      background-attachment: fixed; /* Легкий параллакс-эффект */
    }

    /* Волшебное затемнение для читаемости текста */
    .overlay {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: linear-gradient(
        180deg, 
        rgba(20, 25, 18, 0.5) 0%, 
        rgba(12, 15, 10, 0.7) 50%, 
        rgba(8, 10, 6, 0.85) 100%
      );
      z-index: 1;
    }

    /* Контент размещаем поверх затемнения */
    .content {
      position: relative;
      z-index: 2;
      max-width: 650px;
      width: 100%;
      animation: fadeIn 2s ease-out;
    }

    /* Анимация появления */
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }

    /* Декоративная линия-разделитель */
    .divider {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin: 1.5rem 0;
      color: #c5b18a; /* Золотистый/медный оттенок */
      font-size: 1.2rem;
    }
    .line {
      flex: 1;
      height: 1px;
      background: linear-gradient(to right, transparent, #c5b18a, transparent);
    }

    /* Стили заголовков */
    h1 {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 600;
      font-size: clamp(2.5rem, 8vw, 4.5rem);
      color: #ffffff;
      text-shadow: 0 4px 15px rgba(0,0,0,0.5);
      letter-spacing: 1px;
      margin-bottom: 0.5rem;
    }

    .date-big {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 400;
      font-size: clamp(1.8rem, 6vw, 3rem);
      color: #d8c8a5;
      display: block;
      margin-top: -0.5rem;
      text-shadow: 0 2px 10px rgba(0,0,0,0.6);
    }

    /* Блок с текстом приглашения */
    .invite-text {
      background: rgba(30, 35, 28, 0.4);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      border-radius: 16px;
      padding: 2rem 1.8rem;
      margin: 2rem 0;
      border: 1px solid rgba(197, 177, 138, 0.3);
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
    }

    .invite-text p {
      font-size: 1.1rem;
      font-weight: 300;
      margin-bottom: 1rem;
      text-shadow: 0 2px 5px rgba(0,0,0,0.7);
    }
    
    .invite-text .highlight {
      font-weight: 400;
      color: #e6d7b8;
    }

    /* Блок таймера */
    .timer-section {
      margin: 2.5rem 0 2rem;
    }
    
    .timer-title {
      font-family: 'Cormorant Garamond', serif;
      font-style: italic;
      font-size: 1.4rem;
      color: #c5b18a;
      margin-bottom: 1rem;
    }

    .timer {
      display: flex;
      justify-content: center;
      gap: 1.2rem;
      flex-wrap: wrap;
    }

    .timer-item {
      background: rgba(20, 22, 17, 0.6);
      backdrop-filter: blur(5px);
      -webkit-backdrop-filter: blur(5px);
      border-radius: 12px;
      padding: 0.8rem 0.5rem;
      min-width: 80px;
      border: 1px solid rgba(197, 177, 138, 0.4);
      box-shadow: 0 4px 15px rgba(0,0,0,0.3);
    }

    .timer-number {
      font-family: 'Cormorant Garamond', serif;
      font-size: 2.4rem;
      font-weight: 600;
      color: #ffffff;
      line-height: 1;
    }

    .timer-label {
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 2px;
      color: #c5b18a;
      margin-top: 0.3rem;
    }

    /* Секция с местом проведения */
    .location {
      margin-top: 1.8rem;
    }
    
    .restaurant-name {
      font-family: 'Cormorant Garamond', serif;
      font-size: 2rem;
      font-weight: 600;
      color: #ffffff;
    }

    .address {
      font-size: 1rem;
      color: #d8c8a5;
      margin: 0.5rem 0;
    }

    /* Кнопка добавления в календарь */
    .calendar-btn {
      display: inline-block;
      background: transparent;
      border: 2px solid #c5b18a;
      color: #f0ede8;
      padding: 0.9rem 2.2rem;
      font-family: 'Jost', sans-serif;
      font-size: 1rem;
      font-weight: 400;
      letter-spacing: 1px;
      text-transform: uppercase;
      border-radius: 40px;
      cursor: pointer;
      transition: all 0.4s ease;
      text-decoration: none;
      margin-top: 1.2rem;
      backdrop-filter: blur(4px);
      background: rgba(0,0,0,0.25);
    }

    .calendar-btn:hover {
      background: #c5b18a;
      color: #1a1d18;
      border-color: #c5b18a;
      box-shadow: 0 0 25px rgba(197, 177, 138, 0.5);
    }

    /* Подвал */
    .footer-note {
      margin-top: 3rem;
      font-size: 0.9rem;
      font-style: italic;
      color: #9a9484;
    }

    /* Адаптация для мобильных */
    @media (max-width: 600px) {
      .invitation {
        background-attachment: scroll; /* Убираем параллакс на мобильных для производительности */
        padding: 2rem 1rem;
      }
      .timer {
        gap: 0.5rem;
      }
      .timer-item {
        min-width: 65px;
        padding: 0.6rem 0.3rem;
      }
      .timer-number {
        font-size: 1.8rem;
      }
    }
  </style>
</head>
<body>

  <div class="invitation">
    <div class="overlay"></div>
    
    <div class="content">
      
      <!-- Основной заголовок -->
      <h1>Дорогие родные и близкие!</h1>
      <div class="divider">
        <span class="line"></span>
        <span>✧</span>
        <span class="line"></span>
      </div>
      
      <!-- Текст приглашения -->
      <div class="invite-text">
        <p>
          В нашей жизни предстоят счастливые перемены. Мы хотим, чтобы в этот день рядом с нами были самые дорогие для нас люди.
        </p>
        <p>
          Будем рады разделить с вами этот чудесный праздник в честь нашей любви и союза, который состоится
        </p>
        <span class="date-big">26 июня 2026</span>
      </div>

      <!-- Таймер обратного отсчета -->
      <div class="timer-section">
        <div class="timer-title">До торжества осталось</div>
        <div class="timer" id="timer">
          <div class="timer-item">
            <div class="timer-number" id="days">00</div>
            <div class="timer-label">Дней</div>
          </div>
          <div class="timer-item">
            <div class="timer-number" id="hours">00</div>
            <div class="timer-label">Часов</div>
          </div>
          <div class="timer-item">
            <div class="timer-number" id="minutes">00</div>
            <div class="timer-label">Минут</div>
          </div>
          <div class="timer-item">
            <div class="timer-number" id="seconds">00</div>
            <div class="timer-label">Секунд</div>
          </div>
        </div>
      </div>

      <!-- Детали мероприятия -->
      <div class="invite-text location">
        <p class="highlight">Приглашаем вас на семейный ужин</p>
        <div class="restaurant-name">Sattva</div>
        <p class="address">г. Москва, Ленинградский проспект, 52</p>
        <p>Ждем вас к <strong>16:00</strong><br>в хорошем настроении</p>
      </div>

      <!-- Кнопка Добавить в календарь -->
      <a href="#" class="calendar-btn" id="calendarButton">✧ Добавить в календарь ✧</a>
      
      <div class="footer-note">
        Поддержите нас вашими улыбками и красивыми нарядами
      </div>
    </div>
  </div>

  <script>
    // --- Таймер обратного отсчета ---
    // Устанавливаем дату свадьбы: 26 июня 2026 года, 16:00 по московскому времени
    const weddingDate = new Date('2026-06-26T16:00:00+03:00').getTime();

    function updateTimer() {
      const now = new Date().getTime();
      const distance = weddingDate - now;

      if (distance < 0) {
        document.getElementById('timer').innerHTML = '<div class="timer-title" style="font-size:2rem;">Мы уже женаты! 🎉</div>';
        clearInterval(timerInterval);
        return;
      }

      const days = Math.floor(distance / (1000 * 60 * 60 * 24));
      const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
      const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
      const seconds = Math.floor((distance % (1000 * 60)) / 1000);

      document.getElementById('days').innerText = days.toString().padStart(2, '0');
      document.getElementById('hours').innerText = hours.toString().padStart(2, '0');
      document.getElementById('minutes').innerText = minutes.toString().padStart(2, '0');
      document.getElementById('seconds').innerText = seconds.toString().padStart(2, '0');
    }

    const timerInterval = setInterval(updateTimer, 1000);
    updateTimer(); // Запуск сразу

    // --- Генерация .ics файла для календаря ---
    document.getElementById('calendarButton').addEventListener('click', function(e) {
      e.preventDefault();
      
      // Формируем содержимое ICS файла
      // Обрати внимание: дата в формате YYYYMMDDTHHMMSS
      const startDate = '20260626T130000Z'; // 16:00 МСК = 13:00 UTC
      const endDate = '20260626T180000Z';   // 21:00 МСК = 18:00 UTC (примерное время окончания)
      
      const icsContent = [
        'BEGIN:VCALENDAR',
        'VERSION:2.0',
        'PRODID:-//Wedding Invitation//RU',
        'BEGIN:VEVENT',
        'DTSTART:' + startDate,
        'DTEND:' + endDate,
        'SUMMARY:Свадьба и семейный ужин',
        'DESCRIPTION:Дорогие родные и близкие! Ждем вас на нашем празднике в ресторане Sattva. Пожалуйста, приходите в хорошем настроении!',
        'LOCATION:Ресторан Sattva, г. Москва, Ленинградский проспект, 52',
        'BEGIN:VALARM',
        'TRIGGER:-PT24H',
        'ACTION:DISPLAY',
        'DESCRIPTION:Завтра свадьба! Не забудьте про наряды и улыбки :)',
        'END:VALARM',
        'END:VEVENT',
        'END:VCALENDAR'
      ].join('\r\n');

      const blob = new Blob([icsContent], { type: 'text/calendar;charset=utf-8' });
      const link = document.createElement('a');
      link.href = URL.createObjectURL(blob);
      link.download = 'priglashenie_na_svadbu.ics';
      link.click();
      
      // Небольшой визуальный фидбек
      const btn = document.getElementById('calendarButton');
      const originalText = btn.innerText;
      btn.innerText = '✓ Добавлено!';
      btn.style.background = '#c5b18a';
      btn.style.color = '#1a1d18';
      setTimeout(() => {
        btn.innerText = originalText;
        btn.style.background = 'transparent';
        btn.style.color = '#f0ede8';
      }, 2000);
    });
  </script>
</body>
</html>
